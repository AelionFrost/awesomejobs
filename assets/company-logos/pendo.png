! \u003c/strong\u003ePendo can generally be installed in an hour or less.\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"16px\",\"color\":\"rgba(60, 60, 60, 1)\",\"marginTop\":\"16px\",\"lineHeight\":\"1.6\"}}}]}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"backgroundColor\":\"rgba(255, 255, 255, 1)\",\"borderRadius\":\"8px\",\"padding\":\"24px\",\"cursor\":\"pointer\",\"border\":\"1px solid rgba(230, 230, 230, 1)\",\"transition\":\"all 0.2s ease\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"actions\":{\"click\":\"state.toggleFaq(0)\",\"keyDown\":\"\\n  if (event.key === \\\"Enter\\\" || event.key === \\\" \\\") {\\n    event.preventDefault();\\n    state.toggleFaq(0);\\n  }\\n\"},\"bindings\":{\"tabIndex\":\"0\",\"aria-expanded\":\"state.openFaqIndex === 0\"},\"tagName\":\"div\",\"id\":\"builder-761f969ddf2b4b869da0c254095b7427\",\"properties\":{\"role\":\"button\",\"class\":\"builder-1762974539545-bs73zna1w\"},\"class\":\"builder-1763056533940-0zn1xwcl5\",\"meta\":{\"previousId\":\"builder-aba77106b5684f0992321cc93d5266d5\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"div\",\"id\":\"builder-726e4f1a5fc34dc09a24f576167d350d\",\"meta\":{\"previousId\":\"builder-75bcb618381e4e5caa3c82364c757779\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-92a711c14e9c4294bb8f45277cfd57a8\",\"meta\":{\"previousId\":\"builder-8e9d855febad4a72882f47a696e6aee5\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003eWhat makes Pendo different from other product experience platforms?\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"18px\",\"fontWeight\":\"600\",\"color\":\"rgba(0, 0, 0, 1)\",\"flex\":\"1\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"style.transform\":\"state.openFaqIndex === 0 ? \\\"rotate(180deg)\\\" : \\\"rotate(0deg)\\\"\"},\"tagName\":\"div\",\"id\":\"builder-18538d7f12594399982a9087063d9f5f\",\"meta\":{\"previousId\":\"builder-8e3f776762644389a38e8c8d6854036d\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"svg\",\"id\":\"builder-2aa3fb303d6c4e90a86e25636aa2d841\",\"properties\":{\"width\":\"24\",\"height\":\"24\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\"},\"meta\":{\"previousId\":\"builder-ffc0b763987543709e09a13a0ab47780\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"path\",\"id\":\"builder-9a58e44c480e4f95a3c43ea1e3dfd3e8\",\"properties\":{\"d\":\"M7 10l5 5 5-5\",\"stroke\":\"rgba(0, 0, 0, 1)\",\"strokeWidth\":\"2\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\"},\"meta\":{\"previousId\":\"builder-38ddac5035574e1b86b85662da4e2979\"}}]}],\"responsiveStyles\":{\"large\":{\"width\":\"24px\",\"height\":\"24px\",\"flexShrink\":\"0\",\"transition\":\"transform 0.3s ease\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"justifyContent\":\"space-between\",\"alignItems\":\"center\",\"gap\":\"16px\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"show\":\"state.openFaqIndex === 0\"},\"id\":\"builder-bc0f177616d4465487662f5b70a6a362\",\"meta\":{\"previousId\":\"builder-d3880e30e2394c7e9f5df36c2fcdbc74\"},\"component\":{\"name\":\"Core:Fragment\",\"options\":{},\"isRSC\":null},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-8f838dfa5be24f64a02ad212267aa190\",\"meta\":{\"previousId\":\"builder-5fd9fd3c858b49d7932f9cddf75d1696\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003ePendo is the only platform that unifies product and agent analytics, user feedback, in-app guidance, and AI-powered predictions into a single source of truth for product experience. While other tools force you to stitch together multiple vendors—one for analytics, another for guides, a third for roadmapping—Pendo closes the loop: understand user behavior, capture sentiment, prioritize what to build, and drive adoption with targeted experiences, all from one platform.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cp\u003eThis integrated approach means faster time-to-insight, better cross-functional alignment, and the ability to act on data without switching contexts. Organizations see faster ROI compared to alternatives, with implementations measured in weeks rather than quarters—whether you're a 50-person startup or a Fortune 500 enterprise with thousands of applications.\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"16px\",\"color\":\"rgba(60, 60, 60, 1)\",\"marginTop\":\"16px\",\"lineHeight\":\"1.6\"}}}]}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"backgroundColor\":\"rgba(255, 255, 255, 1)\",\"borderRadius\":\"8px\",\"padding\":\"24px\",\"cursor\":\"pointer\",\"border\":\"1px solid rgba(230, 230, 230, 1)\",\"transition\":\"all 0.2s ease\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"actions\":{\"click\":\"state.toggleFaq(1)\",\"keyDown\":\"\\n  if (event.key === \\\"Enter\\\" || event.key === \\\" \\\") {\\n    event.preventDefault();\\n    state.toggleFaq(1);\\n  }\\n\"},\"bindings\":{\"tabIndex\":\"0\",\"aria-expanded\":\"state.openFaqIndex === 1\"},\"tagName\":\"div\",\"id\":\"builder-dd1a083dbd9a4899b33c608aa93c4b1f\",\"properties\":{\"role\":\"button\",\"class\":\"builder-1762974539545-c25q45a49\"},\"class\":\"builder-1763056533940-odhyf3vg3\",\"meta\":{\"previousId\":\"builder-3c036ebf796e4041ba4497c93a2a43e6\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@ve