ignItems\":\"center\",\"gap\":\"16px\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"show\":\"state.openFaqIndex === 1\"},\"id\":\"builder-9a0b17fc134d42a7bca157257e559be1\",\"meta\":{\"previousId\":\"builder-aa70e1faa94e4603ac8ce246e95a2446\"},\"component\":{\"name\":\"Core:Fragment\",\"options\":{},\"isRSC\":null},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-551129b8000c4e7a81b79d89130e95cd\",\"meta\":{\"previousId\":\"builder-1449b9ce0b0a43e7aaf80b8c71b67df1\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"$27\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"16px\",\"color\":\"rgba(60, 60, 60, 1)\",\"marginTop\":\"16px\",\"lineHeight\":\"1.6\"}}}]}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"backgroundColor\":\"rgba(255, 255, 255, 1)\",\"borderRadius\":\"8px\",\"padding\":\"24px\",\"cursor\":\"pointer\",\"border\":\"1px solid rgba(230, 230, 230, 1)\",\"transition\":\"all 0.2s ease\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"actions\":{\"click\":\"state.toggleFaq(2)\",\"keyDown\":\"\\n  if (event.key === \\\"Enter\\\" || event.key === \\\" \\\") {\\n    event.preventDefault();\\n    state.toggleFaq(2);\\n  }\\n\"},\"bindings\":{\"tabIndex\":\"0\",\"aria-expanded\":\"state.openFaqIndex === 2\"},\"tagName\":\"div\",\"id\":\"builder-a0e3a53db7c7414e93d9c29fc40744be\",\"properties\":{\"role\":\"button\",\"class\":\"builder-1762974539545-og810eebs\"},\"class\":\"builder-1763056533940-mf5k6m8pw\",\"meta\":{\"previousId\":\"builder-e8dc67f1aa244a49b82a3d1844481937\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"div\",\"id\":\"builder-357d04e994d2496696d59964e7a7eda9\",\"meta\":{\"previousId\":\"builder-ada6cdc01fc345a1bc629d9e068c985d\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-cbe3d3021ef24364b1a3f07e37f8e2ce\",\"meta\":{\"previousId\":\"builder-38ff406991f44c2eab56e4a91e07fc21\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003eDo we need a data science team or developers to use Pendo effectively?\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"18px\",\"fontWeight\":\"600\",\"color\":\"rgba(0, 0, 0, 1)\",\"flex\":\"1\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"style.transform\":\"state.openFaqIndex === 2 ? \\\"rotate(180deg)\\\" : \\\"rotate(0deg)\\\"\"},\"tagName\":\"div\",\"id\":\"builder-f46b56006bfc47edadf92b9ee44940e0\",\"meta\":{\"previousId\":\"builder-148bf335962b4cc7be4c4cdc066406ed\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"svg\",\"id\":\"builder-f3c34d8daa2f40d2bc3cbbb8c3f12438\",\"properties\":{\"width\":\"24\",\"height\":\"24\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\"},\"meta\":{\"previousId\":\"builder-bae90bcb4bdf495d90d21d09cfffdc0d\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"path\",\"id\":\"builder-8dcd27f9dfb34c96a505f20bcb2680b4\",\"properties\":{\"d\":\"M7 10l5 5 5-5\",\"stroke\":\"rgba(0, 0, 0, 1)\",\"strokeWidth\":\"2\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\"},\"meta\":{\"previousId\":\"builder-0174186cb8884d788a81459d22045f30\"}}]}],\"responsiveStyles\":{\"large\":{\"width\":\"24px\",\"height\":\"24px\",\"flexShrink\":\"0\",\"transition\":\"transform 0.3s ease\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"justifyContent\":\"space-between\",\"alignItems\":\"center\",\"gap\":\"16px\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"show\":\"state.openFaqIndex === 2\"},\"id\":\"builder-0db6ae4e4b2044208adcd6e0fba1aacf\",\"meta\":{\"previousId\":\"builder-d5259d7b295844c284ace91f6b43d5d7\"},\"component\":{\"name\":\"Core:Fragment\",\"options\":{},\"isRSC\":null},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-3cd83dceda394dc28ba8e5b5654259c8\",\"meta\":{\"previousId\":\"builder-095d43fa307b4bcfbda01f1057fb76d1\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003eNo. Pendo is designed for product, revenue, and IT teams to work independently—with powerful capabilities that can scale to meet enterprise data science and engineering needs when you have them.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cp\u003eNon-technical teams can create segments, build in-app guides, analyze user journeys, and deploy feedback surveys without writing code. Our AI guide builder and visual designer make it simple to launch experiences in minutes. At the same time, Pendo provides API access, data pipeline integrations, custom SQL queries, and advanced analytics for technical teams who want deeper control.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cp\u003eThis \\\"progressive disclosure\\\" approach means your organization can get value immediately while growing sophistication over time. Product teams move fast without tickets to engineering, while IT and data teams have the security, governance, and integration capabilities they require.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"16px\",\"color\":\"rgba(60, 60, 60, 1)\",\"marginTop\":\"16px\",\"lineHeight\":\"1.6\"}}}]}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"backgroundColor\":\"rgba(255, 255, 255, 1)\",\"borderRadius\":\"8px\",\"padding\":\"24px\",\"cursor\":\"pointer\",\"border\":\"1px solid rgba(230, 230, 230, 1)\",\"transition\":\"all 0.2s ease\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"actions\":{\"click\":\"state.toggleFaq(4)\",\"keyDown\":\"\\n  if (event.key === \\\"Enter\\\" || event.key === \\\" \\\") {\\n    event.preventDefault();\\n    state.toggleFaq(4);\\n  }\\n\"},\"bindings\":{\"tabIndex\":\"0\",\"aria-expanded\":\"state.openFaqIndex === 4\"},\"tagName\":\"div\",\"id\":\"builder-c82fa0348703495bbbc8ab540a7d32f1\",\"properties\":{\"class\":\"faq-item\",\"role\":\"button\"},\"class\":\"builder-1763056533941-z6vwhh0oa\",\"meta\":{\"previousId\":\"builder-d2a44903477f49878d297d8083b0dd1e\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"div\",\"id\":\"builder-9b9fb65f3af549fca60ded38235685d2\",\"meta\":{\"previousId\":\"builder-0ae1c9806f72400288b3feec90e9dd1e\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-78e865d51f054b46921e8730fc5a01e8\",\"meta\":{\"previousId\":\"builder-01ec5b1459454d1aa9b5dd33dd0ca729\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003eHow does Pendo scale from our first product to an entire digital portfolio?\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"18px\",\"fontWeight\":\"600\",\"color\":\"rgba(0, 0, 0, 1)\",\"flex\":\"1\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"style.transform\":\"state.openFaqIndex === 4 ? \\\"rotate(180deg)\\\" : \\\"rotate(0deg)\\\"\"},\"tagName\":\"div\",\"id\":\"builder-84f8fc5ea7c3480ba6cb50b2d2e363c6\",\"meta\":{\"previousId\":\"builder-4284d57a2ee345d5a002661d630b945a\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"svg\",\"id\":\"builder-563db5f9faa2457cbf2c164b94f42c7c\",\"properties\":{\"width\":\"24\",\"height\":\"24\",\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"xmlns\":\"http://www.w3.org/2000/svg\"},\"meta\":{\"previousId\":\"builder-46a3c3c7a9694b9095707a3f08270224\"},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"tagName\":\"path\",\"id\":\"builder-f85a1af716c14fc484cde40e1a0525a3\",\"properties\":{\"d\":\"M7 10l5 5 5-5\",\"stroke\":\"rgba(0, 0, 0, 1)\",\"strokeWidth\":\"2\",\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\"},\"meta\":{\"previousId\":\"builder-b526dc9b23d245c6bdc3ba77c73b72bf\"}}]}],\"responsiveStyles\":{\"large\":{\"width\":\"24px\",\"height\":\"24px\",\"flexShrink\":\"0\",\"transition\":\"transform 0.3s ease\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"justifyContent\":\"space-between\",\"alignItems\":\"center\",\"gap\":\"16px\"}}},{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"bindings\":{\"show\":\"state.openFaqIndex === 4\"},\"id\":\"builder-a3cdfcd6efff4068936ebdf6a68271a0\",\"meta\":{\"previousId\":\"builder-45ba5d7e0f7c49dfba318f7b1640349a\"},\"component\":{\"name\":\"Core:Fragment\",\"options\":{},\"isRSC\":null},\"children\":[{\"@type\":\"@builder.io/sdk:Element\",\"@version\":2,\"id\":\"builder-c69b379653174ca8b9f17f634c3fd918\",\"meta\":{\"previousId\":\"builder-54ac01595fd84dc5a54e6b246b6735b6\",\"transformed.text\":\"localized\",\"localizedTextInputs\":[\"text\"]},\"component\":{\"name\":\"Text\",\"options\":{\"text\":\"\u003cp\u003ePendo grows with you. Start by understanding adoption and guiding users in a single product, then expand to track engagement across your entire portfolio—whether that's multiple customer-facing SaaS products, internal applications like Salesforce, or conversational AI agents.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cp\u003eOrganizations use Pendo to manage complex multi-product ecosystems: track cross-product journeys, identify which applications and agents drive the most value, optimize your SaaS spending by measuring actual utilization against licenses, and create consistent experiences across disparate systems. You can deploy Pendo on web, mobile, and AI applications with the same unified analytics and guidance capabilities.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cp\u003eThe platform supports role-based access, SSO/SAML, data governance controls, and integration with your existing tech stack (CRM, data warehouse, support systems)—so it works for both a single product team and an enterprise IT organization managing dozens of applications.\u003c/p\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\"},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"fontSize\":\"16px\",\"color\":\"rgba(60, 60, 60, 1)\",\"marginTop\":\"16px\",\"lineHeight\":\"1.6\"}}}]}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"backgroundColor\":\"rgba(255, 255, 255, 1)\",\"borderRadius\":\"8px\",\"padding\":\"24px\",\"cursor\":\"pointer\",\"border\":\"1px solid rgba(230, 230, 230, 1)\",\"transition\":\"all 0.2s ease\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"position\":\"relative\",\"flexShrink\":\"0\",\"boxSizing\":\"border-box\",\"maxWidth\":\"950px\",\"margin\":\"0 auto\",\"width\":\"100%\",\"gap\":\"16px\"}}}],\"width\":66.666666}],\"space\":20,\"stackColumnsAt\":\"tablet\",\"reverseColumnsWhenStacked\":false},\"isRSC\":null},\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"position\":\"relative\",\"flexShrink\":\"0\",\"boxSizing\":\"border-box\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"position\":\"relative\",\"flexShrink\":\"0\",\"boxSizing\":\"border-box\",\"height\":\"auto\"}}}],\"responsiveStyles\":{\"large\":{\"display\":\"flex\",\"flexDirection\":\"column\",\"position\":\"relative\",\"flexShrink\":\"0\",\"boxSizing\":\"border-box\",\"paddingLeft\":\"20px\",\"paddingRight\":\"20px\",\"marginTop\":\"0px\"},\"smal