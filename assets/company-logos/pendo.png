yle="gap:12px"><a href="/demo-pendo/" style="font-family:var(--font-inter), ui-sans-serif, system-ui, sans-serif;font-weight:400;background-color:#DE2864;color:#FFFFFF;border:2px solid #DE2864;transition:background-color 200ms cubic-bezier(0.22, 1, 0.36, 1), color 200ms cubic-bezier(0.22, 1, 0.36, 1), border-color 200ms cubic-bezier(0.22, 1, 0.36, 1)" class="nav-btn-demo inline-flex items-center justify-center rounded-full px-3 py-1.5 text-[13px] focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40 nav-demo-modal-trigger">Demo</a><button type="button" aria-expanded="false" aria-label="Open navigation menu" class="focus:outline-none focus-visible:ring-2 focus-visible:ring-white/40" style="color:#111111;padding:8px"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16" stroke-linecap="round"></path><path d="M4 12h16" stroke-linecap="round"></path><path d="M4 18h16" stroke-linecap="round"></path></svg></button></div></div><style>
          /* Desktop / drawer split.
             SSR-stable visibility driven by a single media query keyed
             off `dims.drawerBelowPx` (1180) so the chrome and the
             JS-driven `isMobile` boundary pivot at the same width.
             Above 1180: desktop top items + right side visible, drawer
             trigger hidden. At/below 1180: desktop rows hide, the
             drawer trigger row shows. The MobileDrawer itself is still
             mount-gated by the React `isMobile` state in NavBar so it
             only attaches event listeners when actually needed. */
          .nav-desktop-row { display: flex; }
          .nav-mobile-row { display: none; }
          @media (max-width: 1180px) {
            .nav-desktop-row { display: none; }
            .nav-mobile-row { display: flex; }
          }
          .nav-top-link {
            position: relative;
            isolation: isolate;
            transition: color 200ms cubic-bezier(0.22, 1, 0.36, 1);
          }
          .nav-top-link::before {
            content: '';
            position: absolute;
            top: 4px;
            bottom: 4px;
            left: 6px;
            right: 6px;
            border-radius: 9999px;
            background-color: var(--nav-top-hover-bg);
            opacity: 0;
            transition: opacity 200ms cubic-bezier(0.22, 1, 0.36, 1);
            pointer-events: none;
            z-index: -1;
          }
          .nav-top-link:focus-visible::before {
            opacity: 1;
          }
          .nav-top-chevron {
            transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
          }
          .nav-top-chevron-open {
            transform: rotate(180deg);
          }
          .nav-top-link:focus-visible .nav-top-chevron:not(.nav-top-chevron-open) {
            transform: translateY(2px);
          }
          @media (hover: hover) {
            .nav-top-link:hover::before {
              opacity: 1;
            }
            .nav-top-link:hover .nav-top-chevron:not(.nav-top-chevron-open) {
              transform: translateY(2px);
            }
          }
        </style></nav><div style="height:80px;background-color:#000" aria-hidden="true"></div><!--$!--><template data-dgst="BAILOUT_TO_CLIENT_SIDE_RENDERING"></template><!--/$--><style data-emotion-css="dfmn2v">.css-dfmn2v.builder-block{height:0;width:0;display:block;opacity:0;overflow:hidden;pointer-events:none;}</style><img src="https://cdn.builder.io/api/v1/pixel?apiKey=6a96e08774184353b3aa88032e406411" aria-hidden="true" alt="" role="presentation" width="0" height="0" class="builder-block builder-pixel-fc97jorsi6h css-dfmn2v" builder-id="builder-pixel-fc97jorsi6h"/></div></div></div></div><div class="builder-component builder-component-36956b744b96468589215a2b67f1ba0b" data-name="page" data-source="Rendered by Builder.io"><div class="builder-content" builder-content-id="36956b744b96468589215a2b67f1ba0b" builder-model="page"><div data-builder-component="page" data-builder-content-id="36956b744b96468589215a2b67f1ba0b"><style class="builder-custom-styles">.builder-1764011593572-nuw7ud4qq:hover {
