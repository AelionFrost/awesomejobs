html {
  scroll-behavior: smooth;
}

.faqs div[role="button"] {
    transition: ease-in-out 1s;
}

#pendoData .css-elpeqr {
  padding-left:30px;
  padding-right:30px;
}

#rothAndSecurity{
  background: linear-gradient(190deg, #2A2A2A 0%, #101010 40%);

  /* Older Firefox syntax */
  background: -moz-linear-gradient(
    top,
    #2A2A2A 0%,
    #101010 40%,
  );

  /* Standard syntax */
  background: linear-gradient(
    to bottom,
    #2A2A2A 0%,
    #101010 40%,
  );
}
#pendoData .builder-custom-code > section {
  height: auto;
}

#pendoData {
  background: linear-gradient(190deg, #2A2A2A 0%, #101010 50%);

  /* Older Firefox syntax */
  background: -moz-linear-gradient(
    top,
    #2A2A2A 0%,
    #101010 50%,
  );

  /* Standard syntax */
  background: linear-gradient(
    to bottom,
    #2A2A2A 0%,
    #101010 50%,
  );
}

.penny-hero {
  background: #000000; /* fallback */

/* Older WebKit syntax */
background: -webkit-linear-gradient(
  top,
  #000000 35%,
  #2b0007 55%,
  #7a2133 70%,
  #e4b4be 85%,
  #F6F7EF 100%
);

/* Older Firefox syntax */
background: -moz-linear-gradient(
  top,
  #000000 35%,
  #2b0007 55%,
  #7a2133 70%,
  #e4b4be 85%,
  #F6F7EF 100%
);

/* Standard syntax */
background: linear-gradient(
  to bottom,
  #000000 35%,
  #2b0007 55%,
  #7a2133 70%,
  #e4b4be 85%,
  #F6F7EF 100%
);

}


.platform-card {
  border-radius: 20px;
  background: linear-gradient(130deg, #2A2A2A 0%, #101010 100%);

  /* Older Firefox syntax */
  background: -moz-linear-gradient(
    top,
    #2A2A2A 0%,
    #101010 100%,
  );

  /* Standard syntax */
  background: linear-gradient(
    to bottom,
    #2A2A2A 0%,
    #101010 100%,
  );
}

.invert-to-black {
-webkit-filter: invert(1) brightness(0);
-moz-filter: invert(1) brightness(0);
-ms-filter: invert(1) brightness(0);
-o-filter: invert(1) brightness(0);
filter: invert(1) brightness(0);
}
@media (hover: hover) and (pointer: fine) {
  .platform-card-link:hover {
    background:#ffffff;
    transition: all .1s ease-in-out;
  }
}

/* On touch devices, neutralize hover styles */
.is-touch .platform-card-link:hover {
  /* reset whatever Builder is doing on hover */
  transform: none !important;
  background:none !important;
  opacity:1 !important;
}
.is-touch .platform-card-inner:hover {
  opacity:0 !important;
  transform: none !important;
}

.announcement-shelf {
  display: inline-block;
  padding: 0.75rem 1.25rem;
  border-radius: 12px;

  /* Frosted Glass Background */
  background: rgba(255, 102, 153, 0.25); /* translucent pink */
  backdrop-filter: blur(12px) saturate(180%);
  -webkit-backdrop-filter: blur(12px) saturate(180%);

  /* Frosted glass sheen */
  border: 1px solid rgba(255, 255, 255, 0.25);
  box-shadow: inset 0 0 0 0.5px rgba(255, 255, 255, 0.4),
              0 4px 16px rgba(0, 0, 0, 0.15);

  /* Optional text enhancements */
  color: #fff;
}

