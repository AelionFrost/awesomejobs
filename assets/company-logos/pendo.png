1.mediaAlt\",\"tabs.2.label\",\"tabs.2.headline\",\"tabs.2.description\",\"tabs.2.ctaText\",\"tabs.2.mediaAlt\",\"tabs.0.statCards.1.logoAlt\",\"tabs.0.statCards.1.stat\",\"tabs.0.statCards.1.description\",\"tabs.0.statCards.2.logoAlt\",\"tabs.0.statCards.2.stat\",\"tabs.0.statCards.2.description\",\"tabs.1.statCards.0.logoAlt\",\"tabs.1.statCards.0.stat\",\"tabs.1.statCards.0.description\",\"tabs.1.statCards.1.logoAlt\",\"tabs.1.statCards.1.stat\",\"tabs.1.statCards.1.description\",\"tabs.1.statCards.2.logoAlt\",\"tabs.1.statCards.2.stat\",\"tabs.1.statCards.2.description\",\"tabs.2.statCards.0.logoAlt\",\"tabs.2.statCards.0.stat\",\"tabs.2.statCards.0.description\",\"tabs.2.statCards.1.logoAlt\",\"tabs.2.statCards.1.stat\",\"tabs.2.statCards.1.description\",\"tabs.2.statCards.2.logoAlt\",\"tabs.2.statCards.2.stat\",\"tabs.2.statCards.2.description\",\"tabs.3.label\",\"tabs.3.headline\",\"tabs.3.description\",\"tabs.3.ctaText\",\"tabs.3.mediaAlt\",\"tabs.3.statCards.0.logoAlt\",\"tabs.3.statCards.0.stat\",\"tabs.3.statCards.0.description\",\"tabs.3.statCards.1.logoAlt\",\"tabs.3.statCards.1.stat\",\"tabs.3.statCards.1.description\",\"tabs.3.statCards.2.logoAlt\",\"tabs.3.statCards.2.stat\",\"tabs.3.statCards.2.description\"],\"previousId\":\"builder-b4e437df45ec49dab46967de45391480\"},\"component\":{\"name\":\"FramedTabbedSection\",\"options\":{\"tabs\":[{\"id\":\"product\",\"mediaType\":\"wistia\",\"mediaUrl\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F30f1693b660848bf8ff984481887b427\",\"label\":\"Pendo for Product\",\"headline\":\"Turn every release into a revenue moment\",\"description\":\"Product teams move fast, but impact isn't just about shipping, it's about adoption. With Pendo, you can know with certainty what users love, where they struggle, and what they ignore. Guide them to value with in-app help. Watch behavior change and iterate.\",\"ctaText\":\"Pendo for Product teams\",\"ctaLink\":\"/solutions/pendo-for-product/\",\"mediaAlt\":\"Pendo for product teams video\",\"statCards\":[{\"logoAlt\":\"LastPass\",\"stat\":\"+$500K\",\"description\":\"LastPass drove $500K in new bookings by using Pendo Guides to educate users and prompt upgrades.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F66ac8976062c4a3cb3e41584ed7893bb\"},{\"logoAlt\":\"Osmosis from Elsevier\",\"stat\":\"+35%\",\"description\":\"Osmosis increased free-to-paid conversions by 35% after optimizing onboarding with Pendo. \",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2Fce782d7b74c747279c1f21f906f19d20\"},{\"logoAlt\":\"MineralTree\",\"stat\":\"+75-100%\",\"description\":\"MineralTree saw a 75-100% increase in traffic to a key feature after directing users with a Pendo guide.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F3a398d07d08847a0b7fbe4469abd2a80\"}],\"wistiaEmbedUrl\":\"https://pendo-1.wistia.com/medias/jsujlrgobm\"},{\"id\":\"revenue\",\"mediaType\":\"wistia\",\"mediaUrl\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F30f1693b660848bf8ff984481887b427\",\"label\":\"Pendo for Revenue\",\"headline\":\"Data that closes and keeps deals\",\"description\":\"Arm reps with engagement and usage patterns to know which accounts to focus on. Predict churn risks and spot expansion opportunities with AI. Your product data becomes your best proof point and your best predictor.\",\"ctaText\":\"Pendo for Revenue teams\",\"ctaLink\":\"/solutions/pendo-for-revenue/\",\"mediaAlt\":\"Pendo for Sales and Revenue teams video\",\"statCards\":[{\"logoAlt\":\"HackerRank\",\"stat\":\"50%\",\"description\":\"HackerRank reduced at-risk churn by 50% by monitoring customer health and engagement behaviors with Pendo\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2Fd64ca3efb5a348fd9ab4c0dfeae0408d\"},{\"logoAlt\":\"JungleScout\",\"stat\":\"+3X\",\"description\":\"Jungle Scout tripled customer retention by using Pendo onboarding guides to reduce friction and decrease support volume.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F43d6674e0a5241909da2332f41937988\"},{\"logoAlt\":\"Ferguson\",\"stat\":\"2500+\",\"description\":\"Ferguson cut Salesforce training costs for 2,500 employees by leveraging Pendo Product Analytics and In-app Guides.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F8aaceff0796442eea99864138fda7f99\"}],\"wistiaEmbedUrl\":\"https://pendo-1.wistia.com/medias/4t9pli29z1\"},{\"id\":\"it\",\"mediaType\":\"wistia\",\"mediaUrl\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F30f1693b660848bf8ff984481887b427\",\"label\":\"Pendo for IT\",\"headline\":\"Smarter governance. Faster support.\",\"description\":\"Understand what employees use across purchased and homegrown tools. Cut wasteful licenses, deflect support tickets with in-app guidance, and drive adoption of systems that matter. Make every software dollar count.\",\"ctaText\":\"Pendo for IT teams\",\"ctaLink\":\"/solutions/pendo-for-it/\",\"mediaAlt\":\"Pendo for IT teams video\",\"statCards\":[{\"logoAlt\":\"LabCorp\",\"stat\":\"99%\",\"description\":\"LabCorp eliminated a 99% support backlog after using Pendo to pinpoint friction in its digital patient experience.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F94566de790c84e2c9ecc52565574606a\"},{\"logoAlt\":\"JLL\",\"stat\":\"+30\",\"description\":\"JLL boosted internal app NPS by 30 points by improving employee workflows using Pendo behavioral insights.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F86fa32f17d5949c9a8925aeff326f393\"},{\"logoAlt\":\"Essity\",\"stat\":\"1200+\",\"description\":\"Essity onboarded 1,200+ employees across 38 countries using Pendo to automate in-app training and guidance.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F5afab657f84641be883e1d68239b8d68\"}],\"wistiaEmbedUrl\":\"https://pendo-1.wistia.com/medias/j6ikqx2ds4\"},{\"id\":\"marketing\",\"mediaType\":\"wistia\",\"mediaUrl\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F30f1693b660848bf8ff984481887b427\",\"label\":\"Pendo for Marketing\",\"headline\":\"Tap into your most powerful channel\",\"description\":\"Turn your product into a conversion engine. Reach high-intent users with AI-powered campaigns right where they're already engaged. Launch lifecycle marketing without engineering, and prove ROI by connecting campaign performance to product adoption.\",\"ctaText\":\"Pendo for Marketing teams\",\"ctaLink\":\"/solutions/pendo-for-marketing/\",\"mediaAlt\":\"Pendo for Marketing teams video\",\"statCards\":[{\"logoAlt\":\"Keap\",\"stat\":\"1000%\",\"description\":\"Keap saw a 1000% increase in feature adoption after publishing a targeted announcement through a Pendo Guide.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2Ff819dbc669cc4523ba954bee813ca383\"},{\"logoAlt\":\"RingCentral\",\"stat\":\"25%\",\"description\":\"RingCentral’s marketing team increased app retention by 25%. \",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2F73cf4f88308f4fff80ffdd217b76cf35\"},{\"logoAlt\":\"Citrix Sharefile\",\"stat\":\"60%\",\"description\":\"Citrix ShareFile increased free-trial conversions by 60% by personalizing first-login onboarding with Pendo in-app guides.\",\"link\":\"\",\"logo\":\"https://cdn.builder.io/api/v1/image/assets%2F6a96e08774184353b3aa88032e406411%2Fa4efef1dbfc34ff2b07b224ffffcd3a1\"}],\"wistiaEmbedUrl\":\"ht