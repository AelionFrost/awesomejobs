elte-gl7yrj" style="--pb: 100.00%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/3UmeFxih7385AdNEESldX3/766a210959c806030e33e965390ef4a8/Consensys-Trustware-PopUp.png?fm=avif&amp;q=80&amp;w=158&amp;h=158" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/3UmeFxih7385AdNEESldX3/766a210959c806030e33e965390ef4a8/Consensys-Trustware-PopUp.png?fm=webp&amp;q=80&amp;w=158&amp;h=158" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/3UmeFxih7385AdNEESldX3/766a210959c806030e33e965390ef4a8/Consensys-Trustware-PopUp.png?q=80&amp;w=158&amp;h=158" alt="Consensys" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!--]--></figure> <div class="content svelte-1o7mrro"><!--[0--><p class="category svelte-1o7mrro">Ethereum is Trustware.</p><!--]--> <!--[0--><p class="title svelte-1o7mrro">The transition from analog to digital trust is underway. Learn how Ethereum powers the core trust infrastructure for the world.</p><!--]--></div> <span class="external svelte-1o7mrro"><!--[0--><div class="btn svelte-1o7mrro"><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide btn-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!----></div><!--]--></span><!----> <!--[0--><span class="sr-only">(opens in new tab)</span><!--]--><!----></a><!----><!----></div><!--]--><!--]--></section><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-ls2273" data-section="large-title" data-layout="medium-rich-text" data-theme="dark" name="Homepage - Finance is ready for its broadband moment" component="LargeTitle" bottomspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="container content svelte-ls2273"><div class="section-bar svelte-1x9vje0"></div><!----> <div class="title-block svelte-ls2273"><span class="eyebrow svelte-ls2273">INFRASTRUCTURE FOR A NEW GLOBAL ECONOMY</span> <h2 class="title svelte-ls2273"><!--[1--><!---->The internet revolutionized the movement of information, it&#039;s time to do the same for capital.<!----><!--]--><!----></h2></div> <!--[0--><div class="buttons-block svelte-ls2273"><!--[0--><!----><a href="/ethereum/trust" class="btn btn-primary btn-dark tab-focus svelte-b18lfs focus-green" data-sveltekit-noscroll="true"><!--[0--><div class="mask svelte-b18lfs"><span class="btn-text svelte-b18lfs"><!---->Get the Trustware report<!----></span></div><!--]--> <!--[-1--><!--]--> <!--[-1--><!--]--><!----></a><!----><!--]--> <!--[-1--><!--]--></div><!--]--> <!--[0--><div class="rich-text-wrapper decoration-square svelte-ls2273"><div class="richtext "><!----><p>Our financial system is overdue for its broadband moment — and we&#39;re building the platform and infrastructure to enable it. Ethereum makes trust programmable: cryptographic, consensus-driven, and verifiable.</p><p>We call the technology built on this foundation trustware. From MetaMask — the consumer finance platform trusted by millions — to Infura&#39;s developer infrastructure and the protocol clients securing the network, Consensys is building the complete trustware finance stack.</p><!----></div><!----></div><!--]--></div></section><!--]--><!--]--><!--]--></div><!--]--><!----></div></div><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-ls2273" data-section="large-title" data-layout="medium-rich-text" data-theme="light" name="Home - The Open Finance Stack" component="LargeTitle" bottomspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="container content svelte-ls2273"><div class="section-bar svelte-1x9vje0"></div><!----> <div class="title-block svelte-ls2273"><span class="eyebrow svelte-ls2273"></span> <h2 class="title svelte-ls2273"><!--[1--><!---->The Trustware Finance Stack<!----><!--]--><!----></h2></div> <!--[0--><div class="buttons-block svelte-ls2273"><!--[0--><!----><a href="/products" class="btn btn-primary btn-dark tab-focus svelte-b18lfs focus-green" data-sveltekit-noscroll="true"><!--[0--><div class="mask svelte-b18lfs"><span class="btn-text svelte-b18lfs"><!---->See all products<!----></span></div><!--]--> <!--[-1--><!--]--> <!--[-1--><!--]--><!----></a><!----><!--]--> <!--[-1--><!--]--></div><!--]--> <!--[-1--><!--]--></div></section><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-1fhuuyr" data-section="two-up-media" data-layout="half-width" data-theme="light" id="home-our-products-offer-a-powerful-end-to-end-foundation" name="Home - Our products offer a powerful end-to-end foundation" component="TwoUpMedia" bottomspacer="false" disabletopspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="container content svelte-1fhuuyr"><div class="two-cols top svelte-1fhuuyr"><div class="col-block col-1 decoration-square  svelte-1fhuuyr"><!--[0--><h3 class="title svelte-1fhuuyr">Our vertically integrated platform converts user and application intent into successful onchain outcomes, from authorization and routing to execution and settlement.</h3><!--]--></div> <div class="col-block col-2  svelte-1fhuuyr"><!--[-1--><!--]--></div></div> <!--[-1--><!--]--> <!--[-1--><!--]--></div></section><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-j9aw0j" data-section="product-cards-large" data-theme="light" name="Homepage - Product cards large" component="ProductCardsLarge" bottomspacer="false" disabletopspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="card-stack svelte-j9aw0j"><!--[--><div class="large-product-card-wrapper svelte-j9aw0j" data-card-color="gray" data-theme="light"><div class="large-product-card container svelte-j9aw0j"><div class="card-info svelte-j9aw0j"><div class="info svelte-j9aw0j"><!--[-1--><!--]--> <h3 class="title svelte-j9aw0j">MetaMask</h3> <!--[1--><div class="description">MetaMask is the world's most widely adopted self-custodial finance platform, with over millions of users and billions of dollars in digital assets secured. Users send, trade, earn, pay, and connect — all through a single interface backed by integrated transaction security, optimized routing, and cross-chain infrastructure.</div><!--]--> <!--[0--><!----><a href="https://metamask.io/download" rel="noopener noreferrer" target="_blank" class="btn btn-reveal tab-focus  svelte-oxnhfz" data-btn-theme="light" data-sveltekit-noscroll="true"><span class="svelte-oxnhfz"><!---->Download MetaMask<!----></span> <!--[0--><span class="sr-only svelte-oxnhfz">(opens in new tab)</span><!--]--> <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide btn-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!----><!----></a><!----><!--]--></div> <!--[0--><div class="stats svelte-j9aw0j"><!--[--><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Users</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">M</span></h4></div><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Connected Dapps</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">k</span></h4></div><!--]--></div><!--]--></div> <div class="card-carousel svelte-j9aw0j"><div class="carousel  svelte-yvi4dx"><div class="carousel-image-wrapper svelte-yvi4dx"><div class="img-wrapper carousel-image svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="/assets/img/product-card-metamask.webp?fm=avif&amp;q=80" type="image/avif"/> <source srcset="/assets/img/product-card-metamask.webp?fm=webp&amp;q=80" type="image/webp"/> <img src="/assets/img/product-card-metamask.webp?q=80" alt="" role="presentation" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----> <div class="carousel-image-gradient svelte-yvi4dx"></div></div> <div class="carousel-lottie metamask svelte-yvi4dx"><canvas class="lottie-container svelte-yvi4dx"></canvas></div></div><!----></div></div></div><div class="large-product-card-wrapper svelte-j9aw0j" data-card-color="magenta" data-full-background="false" data-theme="light"><div class="large-product-card container svelte-j9aw0j"><div class="card-info svelte-j9aw0j"><div class="info svelte-j9aw0j"><!--[-1--><!--]--> <h3 class="title svelte-j9aw0j">MetaMask Developer</h3> <!--[1--><div class="description">MetaMask Developer enables third-party application builders and agents to integrate with MetaMask and distribute digital asset experiences to millions of users — from wallet connections via the Connect SDK to embedded wallet functionality, all within MetaMask's non-custodial security model.</div><!--]--> <!--[0--><!----><a href="https://metamask.io/developer" rel="noopener noreferrer" target="_blank" class="btn btn-reveal tab-focus  svelte-oxnhfz" data-btn-theme="light" data-sveltekit-noscroll="true"><span class="svelte-oxnhfz"><!---->Explore Developer Products<!----></span> <!--[0--><span class="sr-only svelte-oxnhfz">(opens in new tab)</span><!--]--> <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide btn-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!----><!----></a><!----><!--]--></div> <!--[0--><div class="stats svelte-j9aw0j"><!--[--><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Users</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">M</span></h4></div><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Dapps</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">k+</span></h4></div><!--]--></div><!--]--></div> <div class="card-carousel svelte-j9aw0j"><div class="carousel  svelte-yvi4dx"><div class="carousel-image-wrapper svelte-yvi4dx"><div class="img-wrapper carousel-image svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="/assets/img/product-card-metamask-dev.webp?fm=avif&amp;q=80" type="image/avif"/> <source srcset="/assets/img/product-card-metamask-dev.webp?fm=webp&amp;q=80" type="image/webp"/> <img src="/assets/img/product-card-metamask-dev.webp?q=80" alt="" role="presentation" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----> <div class="carousel-image-gradient svelte-yvi4dx"></div></div> <div class="carousel-lottie metamask-dev svelte-yvi4dx"><canvas class="lottie-container svelte-yvi4dx"></canvas></div></div><!----></div></div></div><div class="large-product-card-wrapper svelte-j9aw0j" data-card-color="red" data-theme="light"><div class="large-product-card container svelte-j9aw0j"><div class="card-info svelte-j9aw0j"><div class="info svelte-j9aw0j"><!--[-1--><!--]--> <h3 class="title svelte-j9aw0j">Infura</h3> <!--[1--><div class="description">Infura is the Internet Service Provider for Ethereum and other blockchain networks — scalable API infrastructure so developers can read and write to supported chains without operating their own nodes. Infura powers thousands of decentralized applications with high-availability endpoints, developer tools, and enterprise-grade performance.</div><!--]--> <!--[0--><!----><a href="https://docs.metamask.io/services/" rel="noopener noreferrer" target="_blank" class="btn btn-reveal tab-focus  svelte-oxnhfz" data-btn-theme="light" data-sveltekit-noscroll="true"><span class="svelte-oxnhfz"><!---->Build with Infura<!----></span> <!--[0--><span class="sr-only svelte-oxnhfz">(opens in new tab)</span><!--]--> <svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide btn-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!----><!----></a><!----><!--]--></div> <!--[0--><div class="stats svelte-j9aw0j"><!--[--><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Requests Served Per Year</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">T</span></h4></div><div class="stat svelte-j9aw0j"><span class="stat-label svelte-j9aw0j">Number of Developers</span> <h4 class="stat-full svelte-j9aw0j"><span class="countup-value "><!--[-1--><!--]--></span><!----> <span class="stat-unit">k</span></h4></div><!--]--></div><!--]--></div> <div class="card-carousel svelte-j9aw0j"><div class="carousel  svelte-yvi4dx"><div class="carousel-image-wrapper svelte-yvi4dx"><div class="img-wrapper carousel-image svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="/assets/img/product-card-infura.webp?fm=avif&amp;q=80" type="image/avif"/> <source srcset="/assets/img/product-card-infura.webp?fm=webp&amp;q=80" type="image/webp"/> <img src="/assets/img/product-card-infura.webp?q=80" alt="" role="presentation" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----> <div class="