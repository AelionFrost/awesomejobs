?fm=avif&amp;q=80" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/KInyVvNIRJZWLeBnLhznc/0b758489bb1b50cbddc6ce344a888d95/besu.png?fm=webp&amp;q=80" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/KInyVvNIRJZWLeBnLhznc/0b758489bb1b50cbddc6ce344a888d95/besu.png?q=80" alt="Besu" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----> <!--[0--><div class="link-overlay svelte-1h58e70"><div class="icon svelte-1h58e70"><!--[-1--><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide " role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!--]--></div></div><!--]--></div> <!--[1--><div class="card-text svelte-bm9j64">An open source Ethereum client for public and private network deployments.</div><!--]--></div><!----> <!--[0--><span class="sr-only">(opens in new tab)</span><!--]--><!----></a><!----><!--]--></div></div></div></section><!--]--><!--]--><!--[0--><!--[--><div class="spline-wrapper svelte-150daw9"><div class="sticky-container svelte-150daw9"><div class="canvas-wrapper svelte-150daw9"><!--[-1--><!--]--> <div class="gradient svelte-150daw9"></div></div></div> <!--[-1--><!--]--> <div class="spline-content svelte-150daw9"><!--[0--><div><!--[--><!--[0--><!--[--><section class="section svelte-1g3849x" data-section="large-offset-cta" data-layout="with-spline" data-theme="dark" id="homepage-saping-ethereum-from-block-0" name="Homepage - Saping Ethereum from Block 0" component="LargeOffsetCta" bottomspacer="false" firstcomponent="true" bottom-spacer="false" disable-top-spacer="false"><div class="container content svelte-1g3849x"><!--[-1--><!--]--> <div class="section-gradient svelte-1g3849x"></div> <!--[0--><div class="section-bar svelte-1x9vje0"></div><!----> <!--[0--><span class="eyebrow svelte-1g3849x">Building Ethereum</span><!--]--><!--]--> <h2 class="title svelte-1g3849x"><!--[0--><!--[--><span class="title-line line-1 svelte-dgsyta"><!---->The Protocol<!----> </span><span class="title-line line-2 svelte-dgsyta"><!---->Powering the<!----> </span><span class="title-line line-3 svelte-dgsyta"><!----><span class="title-highlight">Future of Finance</span><!----></span><!--]--><!--]--><!----></h2> <!--[0--><div class="buttons-block svelte-1g3849x"><!--[0--><!----><a href="/ethereum-upgrade" class="btn btn-primary btn-dark tab-focus svelte-b18lfs focus-green" data-sveltekit-noscroll="true"><!--[0--><div class="mask svelte-b18lfs"><span class="btn-text svelte-b18lfs"><!---->Explore Ethereum upgrades<!----></span></div><!--]--> <!--[-1--><!--]--> <!--[-1--><!--]--><!----></a><!----><!--]--> <!--[-1--><!--]--></div><!--]--></div></section><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-1fhuuyr" data-section="two-up-media" data-layout="full-width" data-theme="dark" id="homepage-from-the-merge-to-pectra-and-beyond" name="Homepage - From The Merge to Pectra and beyond" component="TwoUpMedia" bottomspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="container content svelte-1fhuuyr"><div class="two-cols top svelte-1fhuuyr"><div class="col-block col-1 decoration-square  svelte-1fhuuyr"><!--[0--><h3 class="title svelte-1fhuuyr">From Block 0 through The Merge and beyond, Consensys has been instrumental in Ethereum's evolution into the world's most vital public blockchain — the core trust infrastructure for the global economy.</h3><!--]--></div> <div class="col-block col-2  svelte-1fhuuyr"><!--[2--><div class="richtext "><!----><p>Ethereum enables instant settlement, transparent transactions, and programmable financial services.</p><p>Consensys contributes to every major protocol upgrade, building and maintaining the execution and consensus clients that secure the network.</p><!----></div><!--]--></div></div> <!--[-1--><!--]--> <!--[-1--><!--]--></div></section><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-bymkp7" data-section="research-cards" data-theme="dark" name="Homepage - Research Cards" component="ResearchCards" bottomspacer="false" disabletopspacer="false" firstcomponent="false" bottom-spacer="false" disable-top-spacer="false"><div class="container"><div class="content svelte-bymkp7"><!--[--><!--[0--><div class="research-column svelte-bymkp7"><div class="card-wrapper svelte-bymkp7"><!----><a href="/ethereum-pectra-upgrade" class="article-card-link research-card  tab-focus"><div class="article-card svelte-1rqg820"><div class="card-image-block svelte-1rqg820"><div class="card-image svelte-1rqg820"><div class="img-wrapper  svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/2t3d2pAo5jjreI5nQCe5wb/b84bd113f3d684e1562e10fde034caed/pectra.png?fm=avif&amp;q=80" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/2t3d2pAo5jjreI5nQCe5wb/b84bd113f3d684e1562e10fde034caed/pectra.png?fm=webp&amp;q=80" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/2t3d2pAo5jjreI5nQCe5wb/b84bd113f3d684e1562e10fde034caed/pectra.png?q=80" alt="The Pectra upgrade to the execution and consensus layers introduced Smart Accounts and other powerful features" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----></div> <!--[0--><div class="learn-more svelte-1rqg820"><span class="svelte-1rqg820">Learn More</span> <!--[-1--><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide badge-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14m-7-7l7 7l-7 7"></path></svg><!--]--></div><!--]--></div> <div class="card-info svelte-1rqg820"><!--[0--><span class="card-eyebrow svelte-1rqg820">PECTRA</span><!--]--> <h3 class="card-title svelte-1rqg820">The Pectra upgrade to the execution and consensus layers introduced Smart Accounts and other powerful features</h3> <!--[-1--><!--]--></div></div><!----> <!--[-1--><!--]--><!----></a><!----><!----></div></div><!--]--><!--[0--><div class="research-column svelte-bymkp7"><div class="card-wrapper svelte-bymkp7"><!----><a href="/ethereum-dencun-upgrade" class="article-card-link research-card  tab-focus"><div class="article-card svelte-1rqg820"><div class="card-image-block svelte-1rqg820"><div class="card-image svelte-1rqg820"><div class="img-wrapper  svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/lcQD4A2oI0qSAKzP934iK/a40f8b6a68ff38181601c3839176dae7/dencun.png?fm=avif&amp;q=80" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/lcQD4A2oI0qSAKzP934iK/a40f8b6a68ff38181601c3839176dae7/dencun.png?fm=webp&amp;q=80" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/lcQD4A2oI0qSAKzP934iK/a40f8b6a68ff38181601c3839176dae7/dencun.png?q=80" alt="The Dencun Upgrade introduced proto-danksharding and blobs, making L2s vastly more efficient" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----></div> <!--[0--><div class="learn-more svelte-1rqg820"><span class="svelte-1rqg820">Learn More</span> <!--[-1--><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide badge-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14m-7-7l7 7l-7 7"></path></svg><!--]--></div><!--]--></div> <div class="card-info svelte-1rqg820"><!--[0--><span class="card-eyebrow svelte-1rqg820">Dencun</span><!--]--> <h3 class="card-title svelte-1rqg820">The Dencun Upgrade introduced proto-danksharding and blobs, making L2s vastly more efficient</h3> <!--[-1--><!--]--></div></div><!----> <!--[-1--><!--]--><!----></a><!----><!----></div></div><!--]--><!--[0--><div class="research-column svelte-bymkp7"><div class="card-wrapper svelte-bymkp7"><!----><a href="/merge" class="article-card-link research-card  tab-focus"><div class="article-card svelte-1rqg820"><div class="card-image-block svelte-1rqg820"><div class="card-image svelte-1rqg820"><div class="img-wrapper  svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/6Kcy8SDCoIurjNgRDYDyOe/ee6ca304d10421d744e14b6619f57ba1/the-merge.png?fm=avif&amp;q=80" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/6Kcy8SDCoIurjNgRDYDyOe/ee6ca304d10421d744e14b6619f57ba1/the-merge.png?fm=webp&amp;q=80" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/6Kcy8SDCoIurjNgRDYDyOe/ee6ca304d10421d744e14b6619f57ba1/the-merge.png?q=80" alt="Changing to proof-of-stake, the Merge reduced Ethereum's energy use by 99.95% ensuring sustainable, scalable support for the onchain future" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----></div> <!--[0--><div class="learn-more svelte-1rqg820"><span class="svelte-1rqg820">Learn More</span> <!--[-1--><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide badge-icon" role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14m-7-7l7 7l-7 7"></path></svg><!--]--></div><!--]--></div> <div class="card-info svelte-1rqg820"><!--[0--><span class="card-eyebrow svelte-1rqg820">The Merge</span><!--]--> <h3 class="card-title svelte-1rqg820">Changing to proof-of-stake, the Merge reduced Ethereum's energy use by 99.95% ensuring sustainable, scalable support for the onchain future</h3> <!--[-1--><!--]--></div></div><!----> <!--[-1--><!--]--><!----></a><!----><!----></div></div><!--]--><!--]--></div></div></section><!--]--><!--]--><!--]--></div><!--]--><!----></div></div><!--]--><!--]--><!--[0--><!--[--><section class="section svelte-notwdz" data-section="team-careers" data-theme="dark" id="homepage-team-and-careers" name="Homepage - Team &amp; Careers" component="TeamCareers" bottomspacer="false" disabletopspacer="true" firstcomponent="false" bottom-spacer="false" disable-top-spacer="true"><div class="container"><div class="section-bar svelte-1x9vje0"></div><!----> <div class="content svelte-notwdz"><div class="text-col svelte-notwdz"><div class="title-block svelte-notwdz"><span class="eyebrow svelte-notwdz">FIRST MOVER</span> <h2 class="title svelte-notwdz"><!--[1--><!---->Founded in 2014 by Ethereum co-founder Joseph Lubin, Consensys has been a core contributor to the Ethereum ecosystem since before the genesis block — with a vision to build technology that makes finance more open, accessible, and equitable for everyone.<!----><!--]--><!----></h2> <!--[0--><div class="button-block svelte-notwdz"><!----><a href="/company" class="btn btn-primary btn-dark tab-focus svelte-b18lfs focus-green" data-sveltekit-noscroll="true"><!--[0--><div class="mask svelte-b18lfs"><span class="btn-text svelte-b18lfs"><!---->About Consensys<!----></span></div><!--]--> <!--[-1--><!--]--> <!--[-1--><!--]--><!----></a><!----><!----></div><!--]--></div> <div class="description svelte-notwdz"><div class="richtext "><!----><!----></div><!----></div></div> <div class="image-col svelte-notwdz"><div class="img-wrapper team-image svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/45HwV4q8wBF04ysmIkEC7t/3c92ea7a2381177