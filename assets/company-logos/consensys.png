ill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!--]--></div></div><!--]--></div> <!--[1--><div class="card-text svelte-bm9j64">An Ethereum-equivalent Layer 2 network built with zero-knowledge technology.</div><!--]--></div><!----> <!--[0--><span class="sr-only">(opens in new tab)</span><!--]--><!----></a><!----><!----><a href="/staking" class="small-card-link  tab-focus"><div class="small-product-card link-overlay-trigger svelte-bm9j64"><h3 class="card-title svelte-bm9j64">Consensys Staking</h3> <div class="card-image svelte-bm9j64"><div class="img-wrapper image svelte-gl7yrj" style="--pb: NaN%;"><div class="img svelte-gl7yrj"><!--[-1--><picture class="svelte-gl7yrj"><source srcset="//images.ctfassets.net/gjyjx7gst9lo/1KSKgRXltPf1IzBj7wxAdZ/810d72537534c757796daff1c00dd8cb/consesnsys.png?fm=avif&amp;q=80" type="image/avif"/> <source srcset="//images.ctfassets.net/gjyjx7gst9lo/1KSKgRXltPf1IzBj7wxAdZ/810d72537534c757796daff1c00dd8cb/consesnsys.png?fm=webp&amp;q=80" type="image/webp"/> <img src="//images.ctfassets.net/gjyjx7gst9lo/1KSKgRXltPf1IzBj7wxAdZ/810d72537534c757796daff1c00dd8cb/consesnsys.png?q=80" alt="Consensys Staking" draggable="false" decoding="async" loading="lazy" class="svelte-gl7yrj" onload="this.__e=event"/><!----></picture><!--]--></div> <!----></div><!----> <!--[0--><div class="link-overlay svelte-1h58e70"><div class="icon svelte-1h58e70"><!--[-1--><svg xmlns="http://www.w3.org/2000/svg" width="2em" height="2em" viewBox="4 4 16 16" class="icon icon-lucide " role="presentation"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h10v10M7 17L17 7"></path></svg><!--]--></div></div><!--]--></div> <!--[1--><div class="card-text svelte-bm9j64">Secure, reliable staking infrastructure for institutions.</div><!--]--></div><!----> <!--[-1--><!--]--><!----></a><!----><!----><a href="/teku" class="small-card-lin