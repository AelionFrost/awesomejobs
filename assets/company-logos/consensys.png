ame:"Bill Hughes",excerpt:"Bill Hughes is Senior Counsel and Director of Global Regulatory Matters for Consensys. A seasoned legal expert with a laser focus on the dynamic and continuously transforming landscape of cryptocurrency regulations worldwide, Bill adeptly navigates the intricate legal and public policy challenges that Consensys and the expansive crypto ecosystem face."};B.metadata={tags:[],concepts:[]};B.sys={space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2Xj6gmAwSIs2Q0sPtMZ4fm",type:"Entry",createdAt:"2023-05-23T08:56:08.256Z",updatedAt:"2024-02-27T17:07:12.831Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:9,revision:4,contentType:{sys:{type:"Link",linkType:"ContentType",id:"colorPicker"}},locale:"en-US"};B.fields={name:"Color White",colors:"white"};return {type:"data",data:{page:{name:"Homepage",slug:"homepage",pageSubmenu:false,seo:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"3UDBo3uNfU31axT94FiXrg",type:"Entry",createdAt:"2025-12-04T09:49:29.134Z",updatedAt:"2025-12-17T22:21:46.238Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:4,revision:2,contentType:{sys:{type:"Link",linkType:"ContentType",id:"seo"}},locale:"en-US"},fields:{name:"SEO Metadata - Homepage",title:"Consensys - Building the Era of Decentralized Finance",description:"Consensys is a blockchain software company building the tools, infrastructure and research that power the new Era of Decentralized Finance, for a more secure and open economy",sharedImage:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"KSIfy6249SncAzulCYpbk",type:"Asset",createdAt:"2025-12-04T09:47:55.656Z",updatedAt:"2025-12-19T00:55:32.544Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:16,revision:4,locale:"en-US"},fields:{title:"Consensys - Building the era of decentralized financ