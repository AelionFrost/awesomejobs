,linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Explore the company",title:"Explore the Company",url:"/company"}},submenuLinks:[k,l],menuIcon:"\u003Csvg width=\"180\" height=\"180\" viewBox=\"0 0 180 180\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n\u003Crect class=\"icon-fg\" width=\"180\" height=\"180\" x=\"0\" y=\"0\"/>\n\u003Ccircle class=\"icon-bg\" cx=\"89.9984\" cy=\"90.0001\" r=\"60.6742\"/>\n\u003C/svg>\n",accentColor:"#1437F5"}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"1xJpHKwoYykN1ULUuAHqXN",type:"Entry",createdAt:"2023-05-31T08:53:03.019Z",updatedAt:"2026-05-13T02:25:07.680Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:91,revision:29,contentType:{sys:{type:"Link",linkType:"ContentType",id:"navigationCategory"}},locale:"en-US"},fields:{name:"Blog",title:"Blog",slug:"/blog",highlightedLink:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"1gze8KOSR9kIE5ytFqUgNQ",type:"Entry",createdAt:"2023-05-31T08:52:53.317Z",updatedAt:"2023-05-31T08:52:53.317Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:4,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Explore the blog",title:"Explore the Blog",url:"/blog"}},highlightedArticles:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"4CYGNcpwvifEzpJbTVWd3G",type:"Entry",createdAt:"2026-05-08T16:42:36.577Z",updatedAt:"2026-05-08T17:30:38.739Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:22,revision:6,contentType:{sys:{type:"Link",linkType:"ContentType",id:"pageArticle"}},locale:"en-US"},fields:{title:"America is handing the crypto market to foreign competitors. The CLARITY Act would change that.",slug:"clarity-act-senate-crypto-bill-hughes",seo:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"1Ij15QCvQVHqqGHitmu6GR",type:"Entry",createdAt:"2026-05-08T16:33:56.514Z",updatedAt:"2026-05-08T16:33:56.514Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:23,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"seo"}},locale:"en-US"},fields:{name:"SEO Metadata - America is handing the crypto market to foreign competitors. The CLARITY Act would change that.",title:"The US Is losing crypto to offshore competition. The CLARITY Act changes this.",description:"Consensys' Bill Hughes makes the case for the CLARITY Act, arguing the Senate must pass crypto regulation now to close the competitiveness and national security gaps pushing US trading offshore.",sharedImage:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"7EH7Tsuipbio9lNqXrgtuk",type:"Asset",createdAt:"2026-02-21T04:23:24.348Z",updatedAt:"2026-02-21T04:23:24.348Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:1,locale:"en-US"},fields:{title:"Consensys share image blue",description:"Consensys share image blue",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/7EH7Tsuipbio9lNqXrgtuk/5a1c11c1848bd6719f8a50c13171fc90/Consensys_Symbol_Blue__Share_.png",details:{size:11550,image:{width:1200,height:630}},fileName:"Consensys_Symbol_Blue (Share).png",contentType:"image/png"}}},no_index:false,no_follow:false}},articleTag:[m,n],date:"2026-05-08",thumbnail:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"75gbYDOYUVdWWqO5003Pdh",type:"Asset",createdAt:"2026-02-21T04:18:03.750Z",updatedAt:"2026-02-21T04:18:03.750Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:1,locale:"en-US"},fields:{title:"Consensys thumbnail blue",description:"Consensys thumbnail blue",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/75gbYDOYUVdWWqO5003Pdh/369ab9a38bef2d83b17b367c4cc545b2/Consensys_Symbol_Blue__Thumb_.png",details:{size:33702,image:{width:2160,height:2160}},fileName:"Consensys_Symbol_Blue (Thumb).png",contentType:"image/png"}}},coverImage:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"3hkw4ECF7QAbobXgZK3X0s",type:"Asset",createdAt:"2026-02-21T04:18:51.693Z",updatedAt:"2026-02-21T04:18:51.693Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:1,locale:"en-US"},fields:{title:"Consensys cover image blue",description:"Consensys cover image blue",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/3hkw4ECF7QAbobXgZK3X0s/ea424a00070f17f0e132d8f95eeeb9e3/Consensys_Symbol_Blue__16x9_.png",details:{size:65532,image:{width:3840,height:2160}},fileName:"Consensys_Symbol_Blue (16x9).png",contentType:"image/png"}}},readTime:"5 minutes",introductionText:"The United States is the largest cryptocurrency market on the planet. American users moved over $1 trillion in crypto transactions in the first seven months of 2025 alone. And yet most global crypto trading happens on exchanges that operate out of the Cayman Islands, the Seychelles, and other offshore jurisdictions, testing the reach of US regulators, US courts, and US tax collection. That is not an accident. It reflects a regulatory environment that made it easier to build a digital asset business abroad than at home. The Trump administration has reversed the worst of that posture by ending regulation by enforcement. Now Congress needs to lock in durable change. The Digital Asset Market Clarity Act of 2025, known as the CLARITY Act, is the most serious attempt to do so. The Senate needs to pass it now.",body:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"75oHl6ULLmJ9AhzG0qjWso",type:"Entry",createdAt:"2026-05-08T16:37:10.554Z",updatedAt:"2026-05-08T17:30:31.128Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:42,revision:7,contentType:{sys:{type:"Link",linkType:"ContentType",id:"articleModuleText"}},locale:"en-US"},fields:{name:"America is handing the crypto market to foreign competitors. The CLARITY Act would change that.",text:{nodeType:"document",data:{},content:[{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"The biggest market, capturing almost none of the trading",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The United States is the dominant player in global crypto markets. USD is the world's largest fiat on-ramp for cryptocurrency, accounting for over ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://www.chainalysis.com/blog/2025-global-crypto-adoption-index/"},content:[{nodeType:"text",value:"$2.4 trillion in volume between July 2024 and June 2025",marks:[],data:{}}]},{nodeType:"text",value:", nearly four times the next-highest country. Between January and July 2025, US crypto transaction volume ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://www.trmlabs.com/reports-and-whitepapers/2025-crypto-adoption-and-stablecoin-usage-report"},content:[{nodeType:"text",value:"surged roughly 50% year-over-year",marks:[],data:{}}]},{nodeType:"text",value:" to more than $1 trillion. ",marks:[],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"So where is a lot of that trading actually happening? Not on American exchanges. Binance, the largest offshore venue, controlled roughly ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://www.coingecko.com/research/publications/centralized-crypto-exchanges-market-share"},content:[{nodeType:"text",value:"38% of all centralized spot market share in late 2025",marks:[],data:{}}]},{nodeType:"text",value:". Coinbase, the largest US-regulated spot exchange, reportedly sat below 7% of global spot volume despite operating in the world's biggest fiat market. The picture is starker on the derivatives side, where the top four offshore venues, namely Binance, OKX, Bybit, and Bitget, accounted for roughly ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://www.coinglass.com/learn/2025-annual-report-en"},content:[{nodeType:"text",value:"62% of $86 trillion in 2025 perpetuals volume",marks:[],data:{}}]},{nodeType:"text",value:", with no US-regulated platform among them. ",marks:[],data:{}}]},{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"The national security stakes",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The competitiveness gap is also a national security gap. Crypto trading that happens offshore tests the reach of US anti-money-laundering, sanctions, and counter-terrorism-financing tools. Sanctioned actors tied to Russia, Iran, North Korea, and Venezuela have been using stablecoins routed through offshore venues as connective infrastructure for moving value outside conventional financial controls.",marks:[],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The CLARITY Act addresses this directly by establishing a federal registration and oversight framework for digital commodity exchanges, brokers, dealers, and certain intermediaries operating in US markets. It expands Treasury and FinCEN's visibility into the digital asset ecosystem by directing the application of Bank Secrecy Act and sanctions compliance requirements to covered registrants, including AML programs and sanctions obligations. The bill also strengthens law enforcement authorities through enhanced illicit finance coordination, expanded Section 311 special measures authority for digital asset activity, new transaction monitoring and reporting requirements for certain non-decentralized finance trading protocols, and targeted anti-fraud and compliance requirements for digital asset kiosks. In addition, the legislation creates mechanisms for information sharing between government agencies and designated private sector entities, while preserving Treasury's existing sanctions and anti-money laundering toolkit. The result is a significantly more robust US regulatory perimeter around the digital asset venues and intermediaries used by illicit actors.",marks:[],data:{}}]},{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"Wall Street is waiting for the green light",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"Major US financial institutions, namely banks, asset managers, exchanges, and payment companies, are exploring migrating meaningful parts of their infrastructure onto blockchain rails. The operational case is overwhelming. Faster settlement, lower transaction costs, programmable compliance, and the elimination of the reconciliation breaks that haunt cross-border payments and securities clearing. What has been missing is an affirmative legal framework defining what compliant blockchain-based intermediation looks like. The end of regulation by enforcement was a necessary first step, but prudential regulators, shareholders, and fiduciary duties require a strong legal foundation that institutions can work off of with confidence. The CLARITY Act provides that foundation. With it, billions in TradFi investment in blockchain modernization unlocks, and US consumers and businesses get faster, cheaper, and more reliable financial services.",marks:[],data:{}}]},{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"High-wage American jobs are on the line",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"This is also a story about American jobs. The United States is the largest single-country market for blockchain industry hiring, with ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://coincub.com/us-leads-2025-global-web3-jobs-surge-coincub-report-finds/"},content:[{nodeType:"text",value:"open positions up 26% year-over-year in 2025",marks:[],data:{}}]},{nodeType:"text",value:". US blockchain developers earn an average of $146,250 annually, with experienced professionals ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://algorand.co/blog/blockchain-developer-salary-and-job-outlook-2025"},content:[{nodeType:"text",value:"commanding up to $187,000",marks:[],data:{}}]},{nodeType:"text",value:". These are among the highest-wage technology jobs in the country.",marks:[],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"But that lead has always been fragile. The shift in US policy posture is recent, and companies have endured years of ambiguity because the US market is too valuable to abandon. The durability of that calculus depends on Congress turning the Executive Branch's reset into permanent law. The EU under MiCA, the UK, Singapore, and Dubai are all waiting.",marks:[],data:{}}]},{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"The window is closing, possibly for years",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The CLARITY Act passed the House in July 2025 with a strong bipartisan vote of 294 to 134. The White House is actively driving this effort. The President views blockchain innovation as both economically and politically advantageous, and lawmakers who block the bill risk being blamed if the effort collapses while receiving none of the credit if it ultimately passes. Industry-side disputes over stablecoin yield rules and adjacent issues appear largely resolved. The remaining work is getting a bipartisan product out of the Senate Banking Committee, and the calendar is unforgiving.",marks:[],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"Senator Cynthia Lummis, who chairs the Banking Subcommittee on Digital Assets, has been blunt about the stakes. Failure to pass the bill this year could mean waiting until at least 2030. The Senate has only weeks to move the bill before the August recess, after which the midterm election calendar takes over.",marks:[],data:{}}]},{nodeType:"heading-2",data:{},content:[{nodeType:"text",value:"The people want CLARITY",marks:[{type:"bold"}],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The political calculus here is remarkably clear. ",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://www.harrisx.com/posts/national-survey-of-voters-shows-bipartisan-support-for-american-leadership-in-cryptocurrencies-and-passing-the-clarity-act"},content:[{nodeType:"text",value:"A HarrisX poll released this week",marks:[],data:{}}]},{nodeType:"text",value:" found that 52% of registered voters support the CLARITY Act and just 11% oppose it, with majorities of Republicans (58%) and Democrats (55%) and a strong plurality of independents (42%) all on the same side. About 70% say Congress should have passed the bill already. Senators who vote yes stand to gain a roughly +20 net electoral benefit. Bipartisan legislation is rare in this Congress, and voters are handing the Senate a chance to deliver some.",marks:[],data:{}}]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"CLARITY is not just good policy, it's good politics. It ensures a market that works for Americans and the US dollar, provides law enforcement with durable tools against illicit finance, and allows American institutions to modernize the rails on which finance runs. The Senate should pass it.",marks:[],data:{}}]},{nodeType:"hr",data:{},content:[]},{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"This article was originally shared by ",marks:[{type:"italic"}],data:{}},{nodeType:"hyperlink",data:{uri:"https://x.com/BillHughesDC/status/2052793946431009011?s=20"},content:[{nodeType:"text",value:"Bill Hughes via X",marks:[{type:"italic"}],data:{}}]},{nodeType:"text",value:" on Friday May 8 2026.",marks:[{type:"italic"}],data:{}}]}]}}}],author:o,mainColor:p,heroSplitView:false,showIntroductionTextBelowHero:false}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"1Z6xodzmanCqbNXxxQ8Grp",type:"Entry",createdAt:"2026-05-01T18:32:50.205Z",updatedAt:"2026-05-08T17:00:53.381Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:65,revision:7,contentType:{sys:{type:"Link",linkType:"ContentType",id:"pageArticle"}},locale:"en-US"},fields:{title:"Consensys submits commentary to Treasury Department on regulation of stablecoin issuance and distribution",slug:"commentary-to-treasury-department-regulation-of-stablecoin-issuance-and-distribution",seo:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"1l5Ar7L96nmc0F9SotmlgX",type:"Entry",createdAt:"2026-05-01T18:20:41.071Z",updatedAt:"2026-05-08T16:53:58.317Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:10,revision:2,contentType:{sys:{type:"Link",linkType:"ContentType",id:"seo"}},locale:"en-US"},fields:{name:"SEO Metadata - Consensys submits commentary to Treasury Department on regulation of stablecoin issuance and distribution",title:"Consensys comments on OCC's GENIUS Act stablecoin rules ",description:"Consensys responds to the OCC's proposed GENIUS Act stablecoin rules, urging changes on yield restrictions, DeFi treatment, and multi-brand issuance to keep the market competitive and open.",sharedImage:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2vG1U5tGsv4dD546JuB7H3",type:"Asset",createdAt:"2026-05-08T16:53:49.747Z",updatedAt:"2026-05-08T16:53:52.930Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:7,revision:2,locale:"en-US"},fields:{title:"Consensys red logo shared",description:"Consensys red logo shared",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/2vG1U5tGsv4dD546JuB7H3/7a0a1541759cb83a1df85046148dfb29/Consensys_red_logo_share.png",details:{size:11495,image:{width:1200,height:630}},fileName:"Consensys red logo share.png",contentType:"image/png"}}},no_index:false,no_follow:false}},articleTag:[n,m],date:"2026-05-01",thumbnail:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"F9Jkwj58HciC9luoPDcRW",type:"Asset",createdAt:"2026-05-08T16:49:45.251Z",updatedAt:"2026-05-08T16:49:45.251Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:8,revision:1,locale:"en-US"},fields:{title:"Consensys red logo thumbnail",description:"Consensys red logo thumbnail",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/F9Jkwj58HciC9luoPDcRW/074809abfa589eb5a6dd7076ed5ba459/Consensys_logo_red_thumbnail.png",details:{size:33953,image:{width:2160,height:2160}},fileName:"Consensys logo red thumbnail.png",contentType:"image/png"}}},coverImage:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"27qZCJznin6Ly8s44hs0vt",type:"Asset",createdAt:"2026-05-08T16:50:21.004Z",updatedAt:"2026-05-08T16:50:21.004Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:1,locale:"en-US"},fields:{title:"Consensys red logo header",description:"Consensys red logo header",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/27qZCJznin6Ly8s44hs0vt/b3042e4313d403f5d9f4d2cf1abd071e/Consensys_red_logo_header_image.png",details:{size:65736,image:{width:3840,height:2160}},fileName:"Consensys red logo header image.png",contentType:"image/png"}}},readTime:"5 minutes",introductionText:"The OCC recently proposed rules implementing the GENIUS Act's payment stablecoin framework. It is a serious effort at a hard problem. Consensys filed a comment letter to the Treasury Department this week because we think the OCC got most of it right, but could improve their regime in three specific areas that matter a great deal for how the stablecoin market will develop.",body:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"HzOEIVP0z1SyfV3Wpw3PS",type:"Entry",createdAt:"2026-05-01T18:17:48.918Z",updatedAt:"2026-05-01T18:32:38.277Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:11,revision:4,contentType:{sys:{type:"Link",linkType:"ContentType",id:"articleModuleText"}},locale:"en-US"},fields:{name:"Consensys submits commentary to Treasury Department on regulation of stablecoin issuance and distribution",text:{nodeType:"document",data:{},content:[{nodeType:"paragraph",data:{},content:[{nodeType:"text",value:"The yield question.",marks:[{type:"bold"}],data:{}},{nodeType:"text",value:" The GENIUS Act prohibits stablecoin ",marks:[],data:{}},{nodeType:"text",value:"issuers",marks:[{type:"italic"}],data:{}},{nodeType:"text",value:" from paying interest or yield to holders. Congress did not want stablecoins competing with bank deposits by offering passive returns funded by the reserves backing the stablecoin. We recognize that concern and that Congress spoke unequivocally on the issue.\n\nThe problem is that the OCC's proposed rule extends the prohibition beyond issuers to \"related third parties\", a category that, as drafted, sweeps in independent distribution partners that happen to co-brand or \"white label\" a stablecoin. A distributor that receives a commercial fee for providing a wallet interface and brand, and then independently decides to spend some of that fee on user incentives, is not an issuer paying yield from reserve earnings. It is a business competing for customers with its own money, as every business does. Congress drew this line deliberately, and twice rejected amendments that would have extended the prohibition to non-issuers. The OCC's rule should respect that line.\n\n",marks:[],data:{}},{nodeType:"text",value:"The DeFi question.",marks:[{type:"bold"}],data:{}},{nodeType:"text",value:" When a MetaMask user deposits their stablecoin into Aave or Morpho to earn lending yield, they are making an active investment decision that involves deploying their own assets into a protocol, accepting protocol risk, earning yield from borrowers in that market. That is not the issuer paying them to hold a stablecoin. The GENIUS Act itself carves non-custodial software interfaces out of regulated intermediary status. The final rule should confirm this applies to DeFi access as well.\n\n",marks:[],data:{}},{nodeType:"text",value:"The multi-brand question.",marks:[{type:"bold"}],data:{}},{nodeType:"text",value:" The OCC is considering prohibiting a single licensed issuer from supporting multiple co-branded stablecoins. We think disclosure is the right instrument here, not prohibition. If the concern is that holders don't know which reserves back their stablecoin, tell them. Require issuers to prominently identify themselves and disclose how reserve pools are structured. If that is not sufficient, pool segregation (requiring dedicated reserves for each brand) is a proportionate structural remedy. Prohibition forecloses the distribution model entirely rather than managing the risk it presents, and puts OCC-supervised issuers at a disadvantage relative to FDIC-supervised issuers, who face no equivalent restriction.\n\nThe stablecoin market is still taking shape. The rules written now will determine whether it develops as a competitive, broadly accessible payments infrastructure or consolidates around a small number of institutions large enough to bear every regulatory obligation themselves. It determines how US regulated stablecoins will fair in competition with foreign stablecoins. We appreciate the OCC consider what we have to contribute.\n\n",marks:[],data:{}},{nodeType:"hyperlink",data:{uri:"https://assets.ctfassets.net/gjyjx7gst9lo/2txYnoSxuVpqKIJ0xBo1GF/05bfd3c40da07a55b434eae9d4d48372/Consensys_comment_on_Implementing_the_GENIUS_Act_Subject_to_the_Jurisdiction_of_the_OCC_Docket_ID_OCC_2025_0372_RIN_1557_AF4.pdf"},content:[{nodeType:"text",value:"Read our letter to Treasury Department in full.",marks:[],data:{}}]},{nodeType:"text",value:"",marks:[],data:{}}]}]}}}],author:o,associatedProduct:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2wa3qZ7t3hrxwKUH16OQOI",type:"Entry",createdAt:"2023-10-12T03:27:42.356Z",updatedAt:"2024-10-11T08:05:37.758Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:14,revision:3,contentType:{sys:{type:"Link",linkType:"ContentType",id:"product"}},locale:"en-US"},fields:{title:"Consensys",logo:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2UwuJn90e8CJMC9pUEjRfE",type:"Asset",createdAt:"2023-10-12T03:29:10.062Z",updatedAt:"2023-10-12T03:29:10.062Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:3,revision:1,locale:"en-US"},fields:{title:"consensys-icon",description:"",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/2UwuJn90e8CJMC9pUEjRfE/c5578c9c44f5c5205ad80b54a24001f1/consensys-icon.svg",details:{size:344,image:{width:42,height:41}},fileName:"consensys-icon.svg",contentType:"image/svg+xml"}}},url:"https://consensys.io/"}},mainColor:p,heroSplitView:false,showIntroductionTextBelowHero:false}}],disableSubmenuOnMobile:true,menuIcon:"\u003Csvg width=\"180\" height=\"180\" viewBox=\"0 0 180 180\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" overflow=\"hidden\">\n\u003Cg clip-path=\"url(#clip0_13456_17725)\">\n\u003Crect class=\"icon-fg\" width=\"180\" height=\"180\" x=\"0\" y=\"0\"/>\n\u003Crect class=\"icon-bg\" x=\"0.0878906\" y=\"126\" width=\"54.7826\" height=\"54.7826\"/>\n\u003Crect class=\"icon-bg\" x=\"125.305\" y=\"126\" width=\"54.7826\" height=\"54.7826\"/>\n\u003Crect class=\"icon-bg\" x=\"0.0878906\" width=\"56.7391\" height=\"56.7391\"/>\n\u003Crect class=\"icon-bg\" x=\"123.348\" width=\"56.7391\" height=\"56.7391\"/>\n\u003C/g>\n\u003Cdefs>\n\u003CclipPath id=\"clip0_13456_17725\">\n\u003Crect width=\"180\" height=\"180\" fill=\"white\" transform=\"translate(0.0859375)\"/>\n\u003C/clipPath>\n\u003C/defs>\n\u003C/svg>\n",accentColor:"#E05129"}}],isThemeDark:false}},modules:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"6pqmfiowM2nv1SkZiSh1ZJ",type:"Entry",createdAt:"2025-12-04T09:51:10.384Z",updatedAt:"2025-12-04T09:51:10.384Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:1,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"viewGroup"}},locale:"en-US"},fields:{name:"Homepage - Home Ethereum Hero (Section Wrapper)",component:"Home Ethereum Hero",modules:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"6x4Htj9ttlhmYSJ2IX9bjE",type:"Entry",createdAt:"2025-12-04T09:51:11.367Z",updatedAt:"2026-03-18T15:16:13.691Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:16,revision:8,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleSectionNew"}},locale:"en-US"},fields:{name:"Homepage - Hero",component:"HomeHero",theme:"dark",titleLines:["Building the era of","[Decentralized Finance]"],button1:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2g4bILELoiQ0Al8cBg1LuS",type:"Entry",createdAt:"2025-12-04T09:49:28.237Z",updatedAt:"2025-12-04T11:02:16.186Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:3,revision:2,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Trustware - Explore Trustware products",text:"Explore our products",url:"/products",isReverseLink:false}},button2:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"AEQW0wfIdQXYgoZjfwynf",type:"Entry",createdAt:"2025-12-04T09:50:28.861Z",updatedAt:"2025-12-04T09:50:28.861Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:1,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Learn About Trustware",text:"Learn about Trustware",url:"/ethereum/trust",isReverseLink:false,disableAutoFitThumb:true}},componentVariant:"variant1",longText:"Consensys builds the consumer platform, developer, enterprise, and agentic infrastructure, and protocol software powering the transition to decentralized finance.",list:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"3STBzR3EX1QaeprZPS9DC4",type:"Entry",createdAt:"2024-05-24T20:57:18.704Z",updatedAt:"2025-12-04T10:03:22.691Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:29,revision:9,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleCard"}},locale:"en-US"},fields:{name:"Landing > Hero > Topical Content Box",component:"Default",title:"Ethereum is Trustware.",description:"The transition from analog to digital trust is underway. Learn how Ethereum powers the core trust infrastructure for the world.",url:"/ethereum/trust",external:true,image:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"3UmeFxih7385AdNEESldX3",type:"Asset",createdAt:"2025-12-04T09:47:04.168Z",updatedAt:"2025-12-04T09:47:04.168Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:2,revision:1,locale:"en-US"},fields:{title:"Consensys-Trustware-PopUp",description:"",file:{url:"//images.ctfassets.net/gjyjx7gst9lo/3UmeFxih7385AdNEESldX3/766a210959c806030e33e965390ef4a8/Consensys-Trustware-PopUp.png",details:{size:270096,image:{width:520,height:520}},fileName:"Consensys-Trustware-PopUp.png",contentType:"image/png"}}}}}],bottomSpacer:false}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"wUlgzFxCKbld0IBCLDm8O",type:"Entry",createdAt:"2025-12-04T09:51:09.056Z",updatedAt:"2026-03-19T08:17:48.263Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:12,revision:6,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleSectionNew"}},locale:"en-US"},fields:{name:"Homepage - Finance is ready for its broadband moment",component:"LargeTitle",title:"The internet revolutionized the movement of information, it's time to do the same for capital.",theme:"dark",button1:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2WjEl2180Hdiwv61PQT2lw",type:"Entry",createdAt:"2025-12-04T09:50:29.556Z",updatedAt:"2025-12-04T09:50:29.556Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:1,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Get the Trustware Report",text:"Get the Trustware report",url:"/ethereum/trust",external:false,isReverseLink:false,disableAutoFitThumb:true}},eyebrow:"INFRASTRUCTURE FOR A NEW GLOBAL ECONOMY",componentVariant:"variant4",richText1:{data:{},content:[{data:{},content:[{data:{},marks:[],value:"Our financial system is overdue for its broadband moment — and we're building the platform and infrastructure to enable it. Ethereum makes trust programmable: cryptographic, consensus-driven, and verifiable.",nodeType:"text"}],nodeType:"paragraph"},{data:{},content:[{data:{},marks:[],value:"We call the technology built on this foundation trustware. From MetaMask — the consumer finance platform trusted by millions — to Infura's developer infrastructure and the protocol clients securing the network, Consensys is building the complete trustware finance stack.",nodeType:"text"}],nodeType:"paragraph"}],nodeType:"document"},bottomSpacer:false}}]}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"6TiflSZ7iDW5XhGDgx8Ydq",type:"Entry",createdAt:"2025-12-04T09:51:08.370Z",updatedAt:"2026-03-17T07:48:57.136Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:3,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleSectionNew"}},locale:"en-US"},fields:{name:"Home - The Open Finance Stack",component:"LargeTitle",title:"The Trustware Finance Stack",theme:"light",button1:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"3H9VTNMCFUpM5eKCOhvnJZ",type:"Entry",createdAt:"2025-12-04T09:49:34.044Z",updatedAt:"2025-12-04T09:49:34.044Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:1,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"Button - See all products",text:"See all products",url:"/products",external:false,isReverseLink:false,disableAutoFitThumb:true}},componentVariant:"variant4",bottomSpacer:false}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"xBcs3kiHqbLcFiR8U2fED",type:"Entry",createdAt:"2025-12-04T09:50:50.456Z",updatedAt:"2026-03-17T07:49:22.081Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:3,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleSectionNew"}},locale:"en-US"},fields:{name:"Home - Our products offer a powerful end-to-end foundation",component:"TwoUpMedia",title:"Our vertically integrated platform converts user and application intent into successful onchain outcomes, from authorization and routing to execution and settlement.",theme:"light",componentVariant:"variant2",bottomSpacer:false,id:"home-our-products-offer-a-powerful-end-to-end-foundation",disableTopSpacer:false}},{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2ia4Uwvb7PP7Kn1DidJNNh",type:"Entry",createdAt:"2025-12-04T09:51:06.602Z",updatedAt:"2025-12-04T09:51:06.602Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:1,revision:1,contentType:{sys:{type:"Link",linkType:"ContentType",id:"moduleSectionNew"}},locale:"en-US"},fields:{name:"Homepage - Product cards large",component:"ProductCardsLarge",theme:"light",list:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"7grWLRjL9oMa7NQbC4b0Ug",type:"Entry",createdAt:"2025-12-04T09:50:58.297Z",updatedAt:"2026-03-17T07:50:05.163Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:5,revision:3,contentType:{sys:{type:"Link",linkType:"ContentType",id:"listItemLargeProductCard"}},locale:"en-US"},fields:{internalTitle:"Product Card - MetaMask (Home)",title:"MetaMask",description:"MetaMask is the world's most widely adopted self-custodial finance platform, with over millions of users and billions of dollars in digital assets secured. Users send, trade, earn, pay, and connect — all through a single interface backed by integrated transaction security, optimized routing, and cross-chain infrastructure.",link:{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"2Ox6VBV9LG3a2crr0ra0eQ",type:"Entry",createdAt:"2025-12-04T09:50:43.523Z",updatedAt:"2025-12-04T11:05:50.783Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:3,revision:2,contentType:{sys:{type:"Link",linkType:"ContentType",id:"linkBlock"}},locale:"en-US"},fields:{name:"MetaMask",title:"MetaMask",text:"Download MetaMask",url:"https://metamask.io/download",external:true}},stats:[{metadata:{tags:[],concepts:[]},sys:{space:{sys:{type:"Link",linkType:"Space",id:"gjyjx7gst9lo"}},id:"4X7aoxClMLED0FFnWhVo58",type:"Entry",createdAt:"2025-12-04T09:50:18.304Z",updatedAt:"2025-12-04T11:05:42.723Z",environment:{sys:{id:"master",type:"Link",linkType:"Environment"}},publishedVersion:3,revision:2,contentType:{sys:{type:"Link",linkType:"ContentType",id:"statistics"}},lo